  "keyFeatures": [
    "MongoDB-like query syntax with operators ($eq, $gt, $in, $regex, etc.)",
    "Zero external dependencies - runs on Node.js built-ins only",
    "File-based JSONL storage with automatic metadata tracking",
    "Chainable query builder with sorting, pagination, and projection",
    "In-memory LRU caching for performance optimization",
    "Automatic indexing with hash and sorted indices",
    "Event-driven architecture with EventEmitter",
    "Batched asynchronous writes with automatic compaction",
    "Aggregation operations (sum, avg, min, max, count)",
    "Support for complex queries with AND/OR conditions"
  ],
  "publicApiSurface": [
    "AmoraDB(name, options)",
    "db.init()",
